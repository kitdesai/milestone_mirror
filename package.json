{
  "name": "milestone-mirror",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:dev": "npx wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "pages:deploy": "npm run pages:build && npx wrangler pages deploy .vercel/output/static",
    "db:create": "npx wrangler d1 create milestone-mirror-db",
    "db:migrate": "npx wrangler d1 execute milestone-mirror-db --file=./db/schema.sql",
    "db:migrate:local": "npx wrangler d1 execute milestone-mirror-db --local --file=./db/schema.sql"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lucia-auth/adapter-sqlite": "^3.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "critters": "^0.0.25",
    "date-fns": "^4.1.0",
    "face-api.js": "^0.22.2",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.2",
    "lucia": "^3.2.2",
    "marked": "^18.0.1",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "stripe": "^22.0.1"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260203.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "wrangler": "^4.81.0"
  }
}
